# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Origin of your frontend (use * to allow all during development)
ALLOWED_ORIGIN=https://lucky-eunwoo-cafe.vercel.app

# ── Firebase ──────────────────────────────────────────────────────────────────
#
# OPTION A  (recommended for local dev)
# Download the service account JSON from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the file next to .env and set the path below:
#
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# OPTION B  (recommended for production / cloud hosting)
# Copy each value from the service account JSON file:
#
FIREBASE_PROJECT_ID=lucky-eunwoo-cafe
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lucky-eunwoo-cafe.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your-private-key-here

FIREBASE_STORAGE_BUCKET=lucky-eunwoo-cafe.firebasestorage.app

